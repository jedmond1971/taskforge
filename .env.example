# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/taskforge"

# NextAuth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Required by NextAuth v5
AUTH_SECRET="your-secret-here"

# Railway Object Storage (optional — for file attachments)
# Provision a bucket in your Railway project to get these values
RAILWAY_BUCKET_ENDPOINT="https://<region>.storageapi.dev"
RAILWAY_BUCKET_ACCESS_KEY_ID="your-access-key-id"
RAILWAY_BUCKET_SECRET_ACCESS_KEY="your-secret-access-key"
RAILWAY_BUCKET_NAME="your-bucket-name"
RAILWAY_BUCKET_REGION="auto"
