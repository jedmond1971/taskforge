# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/taskforge"

# NextAuth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
