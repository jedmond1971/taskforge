generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEAM_MEMBER
  VIEWER
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum ProjectMemberRole {
  PROJECT_LEAD
  TEAM_MEMBER
  VIEWER
}

enum IssueStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum IssuePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IssueType {
  BUG
  TASK
  STORY
  EPIC
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  role         UserRole @default(TEAM_MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectMembers ProjectMember[]
  assignedIssues Issue[]         @relation("AssignedIssues")
  reportedIssues Issue[]         @relation("ReportedIssues")
  comments       Comment[]
  activityLogs   ActivityLog[]
  savedFilters   SavedFilter[]
  attachments    Attachment[]
  ownedOrgs      Organization[]  @relation("OwnedOrgs")
  orgMembers     OrgMember[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  description String?
  orgId       String
  isPrivate   Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org     Organization  @relation(fields: [orgId], references: [id])
  members ProjectMember[]
  issues  Issue[]
  boards  Board[]
}

model ProjectMember {
  id        String            @id @default(cuid())
  userId    String
  projectId String
  role      ProjectMemberRole @default(TEAM_MEMBER)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

model Issue {
  id          String        @id @default(cuid())
  projectId   String
  key         String        @unique
  title       String
  description String?
  status      IssueStatus   @default(TODO)
  priority    IssuePriority @default(MEDIUM)
  type        IssueType     @default(TASK)
  assigneeId  String?
  reporterId  String
  parentId    String?
  position    Int           @default(0)
  labels      String[]      @default([])
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?    @relation("AssignedIssues", fields: [assigneeId], references: [id])
  reporter User     @relation("ReportedIssues", fields: [reporterId], references: [id])
  parent   Issue?   @relation("SubIssues", fields: [parentId], references: [id])
  children Issue[]  @relation("SubIssues")

  comments     Comment[]
  activityLogs ActivityLog[]
  attachments  Attachment[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([status])
  @@index([priority])
}

model Board {
  id        String @id @default(cuid())
  projectId String
  name      String

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns Column[]

  @@index([projectId])
}

model Column {
  id       String @id @default(cuid())
  boardId  String
  name     String
  position Int
  color    String @default("#94a3b8")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
}

model Comment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([issueId])
}

model SavedFilter {
  id        String   @id @default(cuid())
  name      String
  query     String
  userId    String
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  issueId   String
  userId    String
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([userId])
}

model Attachment {
  id         String   @id @default(cuid())
  issueId    String
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  uploaderId String
  uploader   User     @relation(fields: [uploaderId], references: [id])
  fileName   String
  fileKey    String
  fileSize   Int
  mimeType   String
  createdAt  DateTime @default(now())

  @@index([issueId])
  @@index([uploaderId])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User           @relation("OwnedOrgs", fields: [ownerId], references: [id])
  members      OrgMember[]
  invites      OrgInvite[]
  subscription Subscription?
  projects     Project[]
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole  @default(MEMBER)
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model OrgInvite {
  id        String   @id @default(cuid())
  orgId     String
  email     String
  token     String   @unique @default(cuid())
  role      OrgRole  @default(MEMBER)
  accepted  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([token])
}

model Subscription {
  id                   String             @id @default(cuid())
  orgId                String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}
