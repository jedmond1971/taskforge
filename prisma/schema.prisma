generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEAM_MEMBER
  VIEWER
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum ProjectMemberRole {
  PROJECT_LEAD
  TEAM_MEMBER
  VIEWER
}

enum StatusCategory {
  TODO
  IN_PROGRESS
  DONE
}

enum IssuePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IssueType {
  BUG
  TASK
  STORY
  EPIC
}

enum NotificationType {
  ISSUE_ASSIGNED
  COMMENT_ADDED
  STATUS_CHANGED
  MENTION
}

enum DocPageType {
  NATIVE
  DOCUMENT
}

enum IssueLinkType {
  BLOCKS
  RELATES_TO
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  CHECKBOX
  SELECT
  MULTI_SELECT
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  role           UserRole @default(TEAM_MEMBER)
  sessionVersion Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectMembers ProjectMember[]
  assignedIssues Issue[]         @relation("AssignedIssues")
  reportedIssues Issue[]         @relation("ReportedIssues")
  comments       Comment[]
  activityLogs   ActivityLog[]
  savedFilters   SavedFilter[]
  attachments    Attachment[]
  ownedOrgs      Organization[]  @relation("OwnedOrgs")
  orgMembers     OrgMember[]
  notifications  Notification[]
  docPages           DocPage[]
  pageRevisions      PageRevision[]
  issueDocLinks      IssueDocLink[]
  issueLinks         IssueLink[]
  invitedOrgInvites  OrgInvite[]    @relation("InvitedBy")
  adminAuditLogs     AdminAuditLog[]
  apiKeys            ApiKey[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  description String?
  orgId       String
  isPrivate   Boolean  @default(false)
  isClosed    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org                      Organization         @relation(fields: [orgId], references: [id])
  members                  ProjectMember[]
  issues                   Issue[]
  statuses                 ProjectStatus[]
  boards                   Board[]
  docSpace                 DocSpace?
  savedFilters             SavedFilter[]
  customFieldRestrictions  CustomFieldProject[]
}

model ProjectMember {
  id        String            @id @default(cuid())
  userId    String
  projectId String
  role      ProjectMemberRole @default(TEAM_MEMBER)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

model Issue {
  id          String        @id @default(cuid())
  projectId   String
  key         String        @unique
  title       String
  description String?
  statusId    String
  priority    IssuePriority @default(MEDIUM)
  type        IssueType     @default(TASK)
  assigneeId  String?
  reporterId  String
  parentId    String?
  position    Int           @default(0)
  labels      String[]      @default([])
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectStatus ProjectStatus @relation(fields: [statusId], references: [id])
  assignee      User?         @relation("AssignedIssues", fields: [assigneeId], references: [id])
  reporter      User          @relation("ReportedIssues", fields: [reporterId], references: [id])
  parent        Issue?        @relation("SubIssues", fields: [parentId], references: [id])
  children      Issue[]       @relation("SubIssues")

  comments          Comment[]
  activityLogs      ActivityLog[]
  attachments       Attachment[]
  notifications     Notification[]
  docLinks          IssueDocLink[]
  outgoingLinks     IssueLink[]         @relation("SourceLinks")
  incomingLinks     IssueLink[]         @relation("TargetLinks")
  customFieldValues CustomFieldValue[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([statusId])
  @@index([priority])
  // Position uniqueness enforced by DEFERRABLE constraint in migration
  // (not expressible as @@unique — reorder logic writes sequentially)
  @@index([projectId, statusId, position])
}

model Board {
  id        String @id @default(cuid())
  projectId String
  name      String

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns Column[]

  @@index([projectId])
}

model Column {
  id       String @id @default(cuid())
  boardId  String
  name     String
  position Int
  color    String @default("#94a3b8")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
}

model ProjectStatus {
  id        String         @id @default(cuid())
  projectId String
  name      String
  category  StatusCategory
  position  Int
  isDefault Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@unique([projectId, name])
  @@index([projectId, category, position])
}

model Comment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([issueId])
}

model SavedFilter {
  id        String   @id @default(cuid())
  name      String
  query     String
  userId    String
  projectId String
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  issueId   String
  userId    String?
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  // Issue delete cascades and removes all activity log rows for that issue.
  // User delete nullifies userId to preserve audit history (not a hard delete).
  issue Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([issueId])
  @@index([userId])
}

model Attachment {
  id         String   @id @default(cuid())
  issueId    String
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  uploaderId String
  uploader   User     @relation(fields: [uploaderId], references: [id])
  fileName   String
  fileKey    String
  fileSize   Int
  mimeType   String
  createdAt  DateTime @default(now())

  @@index([issueId])
  @@index([uploaderId])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User           @relation("OwnedOrgs", fields: [ownerId], references: [id])
  members      OrgMember[]
  invites      OrgInvite[]
  subscription Subscription?
  projects     Project[]
  customFields CustomField[]
  apiKeys      ApiKey[]
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole  @default(MEMBER)
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model OrgInvite {
  id          String    @id @default(cuid())
  orgId       String
  email       String
  token       String    @unique @default(cuid())
  role        OrgRole   @default(MEMBER)
  accepted    Boolean   @default(false)
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  invitedById String

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@unique([orgId, email])
  @@index([token])
}

model Subscription {
  id                   String             @id @default(cuid())
  orgId                String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  message   String
  userId    String
  issueId   String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue Issue? @relation(fields: [issueId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model DocSpace {
  id        String   @id @default(cuid())
  projectId String   @unique
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sections DocSection[]
  pages    DocPage[]
}

model DocSection {
  id         String   @id @default(cuid())
  docSpaceId String
  title      String
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  docSpace DocSpace  @relation(fields: [docSpaceId], references: [id], onDelete: Cascade)
  pages    DocPage[]

  @@index([docSpaceId])
  // Position uniqueness enforced by DEFERRABLE constraint in migration
  // (not expressible as @@unique — reorder logic writes sequentially)
  @@index([docSpaceId, position])
}

model DocPage {
  id         String      @id @default(cuid())
  docSpaceId String
  sectionId  String?
  title      String
  type       DocPageType @default(NATIVE)
  content    String?
  fileKey    String?
  fileSize   Int?
  mimeType   String?
  authorId   String
  position   Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  docSpace   DocSpace       @relation(fields: [docSpaceId], references: [id], onDelete: Cascade)
  section    DocSection?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  author     User           @relation(fields: [authorId], references: [id])
  revisions  PageRevision[]
  issueLinks IssueDocLink[]

  @@index([docSpaceId])
  @@index([sectionId])
  @@index([authorId])
  // Position uniqueness enforced by DEFERRABLE constraint in migration
  // (not expressible as @@unique — sectionId is nullable; partial indexes handle
  //  sectioned pages (deferrable) and top-level pages (non-deferrable partial index))
  @@index([docSpaceId, sectionId, position])
}

model PageRevision {
  id        String   @id @default(cuid())
  pageId    String
  content   String
  authorId  String
  createdAt DateTime @default(now())

  page   DocPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author User    @relation(fields: [authorId], references: [id])

  @@index([pageId])
}

model IssueDocLink {
  id          String   @id @default(cuid())
  issueId     String
  pageId      String
  createdById String
  createdAt   DateTime @default(now())

  issue     Issue   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  page      DocPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@unique([issueId, pageId])
  @@index([issueId])
  @@index([pageId])
}

model IssueLink {
  id            String        @id @default(cuid())
  sourceIssueId String
  targetIssueId String
  linkType      IssueLinkType
  createdById   String
  createdAt     DateTime      @default(now())

  sourceIssue Issue @relation("SourceLinks", fields: [sourceIssueId], references: [id], onDelete: Cascade)
  targetIssue Issue @relation("TargetLinks", fields: [targetIssueId], references: [id], onDelete: Cascade)
  createdBy   User  @relation(fields: [createdById], references: [id])

  @@unique([sourceIssueId, targetIssueId, linkType])
  @@index([sourceIssueId])
  @@index([targetIssueId])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorName   String
  actorEmail  String
  action      String
  targetType  String
  targetId    String?
  targetLabel String
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model ApiKey {
  id          String    @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  keyPrefix   String
  hashedKey   String    @unique
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([orgId])
}

model CustomField {
  id        String          @id @default(cuid())
  orgId     String
  name      String
  type      CustomFieldType
  options   String[]        @default([])
  position  Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectRestrictions CustomFieldProject[]
  values              CustomFieldValue[]

  @@unique([orgId, name])
  @@index([orgId])
}

model CustomFieldProject {
  id            String @id @default(cuid())
  customFieldId String
  projectId     String

  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, projectId])
  @@index([customFieldId])
  @@index([projectId])
}

model CustomFieldValue {
  id            String    @id @default(cuid())
  customFieldId String
  issueId       String
  textValue     String?
  numberValue   Float?
  dateValue     DateTime?
  boolValue     Boolean?
  selectValue   String?
  multiValues   String[]  @default([])
  updatedAt     DateTime  @updatedAt

  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  issue       Issue       @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, issueId])
  @@index([issueId])
  @@index([customFieldId])
}
